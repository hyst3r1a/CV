#!/bin/sh
# Maven wrapper script – standard Apache Maven Wrapper

if [ -z "$JAVA_HOME" ] ; then
  JAVACMD=java
else
  JAVACMD="$JAVA_HOME/bin/java"
fi

MAVEN_WRAPPER_JAR=".mvn/wrapper/maven-wrapper.jar"
MAVEN_WRAPPER_PROPERTIES=".mvn/wrapper/maven-wrapper.properties"

DISTRIBUTION_URL=$(grep "distributionUrl" "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2)

if [ -f "$MAVEN_WRAPPER_JAR" ]; then
  exec "$JAVACMD" -jar "$MAVEN_WRAPPER_JAR" "$@"
fi

# Download wrapper jar if missing
WRAPPER_JAR_URL=$(grep "wrapperUrl" "$MAVEN_WRAPPER_PROPERTIES" | cut -d'=' -f2)
mkdir -p ".mvn/wrapper"
if command -v curl > /dev/null 2>&1; then
  curl -o "$MAVEN_WRAPPER_JAR" -fsSL "$WRAPPER_JAR_URL"
elif command -v wget > /dev/null 2>&1; then
  wget -q -O "$MAVEN_WRAPPER_JAR" "$WRAPPER_JAR_URL"
fi

exec "$JAVACMD" -jar "$MAVEN_WRAPPER_JAR" "$@"
